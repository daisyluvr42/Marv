{
  "name": "@marv/mattermost",
  "version": "2026.4.27",
  "private": true,
  "description": "Marv Mattermost channel plugin",
  "type": "module",
  "peerDependencies": {
    "agentmarv": ">=2026.1.26"
  },
  "marv": {
